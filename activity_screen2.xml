<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F0EB"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="40dp">

        <!-- ═══ HEADER (identique à l'écran 1) ═══ -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="220dp"
            android:background="#1A1A2E">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:orientation="vertical"
                android:paddingHorizontal="30dp"
                android:gravity="center_horizontal">

                <TextView
                    android:text="USER INFORMATIONS"
                    android:textColor="#C9A84C"
                    android:textSize="11sp"
                    android:letterSpacing="0.3"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:text="Vérifiez Vos Informations"
                    android:textColor="#FFFFFF"
                    android:textSize="32sp"
                    android:fontFamily="serif"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:text="Vous pouvez revenir pour corriger"
                    android:textColor="#9999AA"
                    android:textSize="13sp"
                    android:fontFamily="sans-serif-light"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>
        </RelativeLayout>

        <!-- ═══ CARTE RÉCAPITULATIF ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="-24dp"
            android:elevation="8dp"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <!-- Badge "Informations reçues" -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="5dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginBottom="16dp">

                <View
                    android:layout_width="7dp"
                    android:layout_height="7dp"
                    android:layout_marginEnd="6dp"/>

                <TextView
                    android:text="INFORMATION RECUS"
                    android:textColor="#7E7DA1"
                    android:textSize="16sp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <!-- ─── Ligne : Nom ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">

                <TextView
                    android:text="NOM"
                    android:textColor="#C9A84C"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvNom"
                    android:text="—"
                    android:textColor="#1A1A2E"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0EBE3"/>

            <!-- ─── Ligne : Email ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">

                <TextView
                    android:text="EMAIL"
                    android:textColor="#C9A84C"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvEmail"
                    android:text="—"
                    android:textColor="#1A1A2E"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0EBE3"/>

            <!-- ─── Ligne : Téléphone ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">

                <TextView
                    android:text="TÉLÉPHONE"
                    android:textColor="#C9A84C"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvPhone"
                    android:text="—"
                    android:textColor="#1A1A2E"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0EBE3"/>

            <!-- ─── Ligne : Adresse ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">

                <TextView
                    android:text="ADRESSE"
                    android:textColor="#C9A84C"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvAdresse"
                    android:text="—"
                    android:textColor="#1A1A2E"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#F0EBE3"/>

            <!-- ─── Ligne : Ville ─── -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingVertical="12dp">

                <TextView
                    android:text="VILLE"
                    android:textColor="#C9A84C"
                    android:textSize="9sp"
                    android:letterSpacing="0.2"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/tvVille"
                    android:text="—"
                    android:textColor="#1A1A2E"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>
            </LinearLayout>

        </LinearLayout>

        <!-- ═══ BOUTON RETOUR ═══ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btnVerifie"
                android:text="✔ VERIFIE"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFF"
                android:textSize="13sp"
                android:letterSpacing="0.2"
                android:fontFamily="sans-serif-medium"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:stateListAnimator="@null"/>

            <Button
                android:id="@+id/btnRetour"
                android:text="↩ RETOUR"
                android:backgroundTint="#F44336"
                android:textColor="#FFF"
                android:textSize="13sp"
                android:letterSpacing="0.2"
                android:fontFamily="sans-serif-medium"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:stateListAnimator="@null"/>

            <TextView
                android:text="By Mourad EL OUATIK ©"
                android:textColor="#999999"
                android:textSize="11sp"
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
